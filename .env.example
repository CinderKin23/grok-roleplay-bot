# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, local
LLM_API_KEY=your_api_key_here
MODEL=gpt-4-turbo

# Optional: For local models (Ollama, etc.)
LOCAL_MODEL_URL=http://localhost:11434

# Bot Behavior
MAX_CONTEXT_LENGTH=4096
TEMPERATURE=0.8
TOP_P=0.95

# Logging
DEBUG=false
LOG_LEVEL=INFO